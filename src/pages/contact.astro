---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact – Ensō Athens Martial Arts">
<section class="page-hero">
      <p class="page-hero-eyebrow" data-i18n="contact.hero.eyebrow">Get in Touch</p>
      <h1>
        CONTACT
        <br />
        US
      </h1>
      <p data-i18n="contact.hero.p">
        Have questions about our classes? Ready to book a free trial? We're available 7 days a week.
      </p>
    </section>

    <div class="contact-grid" id="form">
      <div class="contact-info fade-up">
        <h2 data-i18n-html="contact.info.h2">
          We're Here to
          <br />
          Support Your Journey
        </h2>

        <div class="contact-item">
          <h4>
            <span class="contact-item-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="width: 16px; height: 16px"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l1.8-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                />
              </svg>
            </span>
            <span data-i18n="contact.call.h4">Call or Text</span>
          </h4>
          <a href="tel:+306971767652">+30 697 176 7652</a>
          <p
            style="font-size: 13px; margin-top: 4px; color: rgba(245, 240, 232, 0.45)"
            data-i18n="contact.call.sub"
          >
            Available 24/7, 7 days a week
          </p>
        </div>

        <div class="contact-item">
          <h4>
            <span class="contact-item-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="width: 16px; height: 16px"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </span>
            <span data-i18n="contact.email.h4">Email</span>
          </h4>
          <a href="mailto:ensoathens@gmail.com">ensoathens@gmail.com</a>
        </div>

        <div class="contact-item">
          <h4>
            <span class="contact-item-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="width: 16px; height: 16px"
              >
                <path d="M20 10c0 6-8 13-8 13s-8-7-8-13a8 8 0 0 1 16 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <span data-i18n="contact.visit.h4">Visit Us</span>
          </h4>
          <a href="https://share.google/P7tDznBGuPWAmPiDz" target="_blank" rel="noopener">
            Thessalonikis 35, Athens 118 51, Greece
          </a>
          <p
            style="font-size: 13px; margin-top: 4px; color: rgba(245, 240, 232, 0.45)"
            data-i18n="contact.visit.sub"
          >
            Easy access from public transport · Nearby parking
          </p>
        </div>

        <div style="margin-top: 48px; padding-top: 48px; border-top: 1px solid var(--border)">
          <p
            class="section-eyebrow"
            style="margin-bottom: 16px"
            data-i18n="contact.programs.eyebrow"
          >
            Programs Available
          </p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 10px">
            <li
              style="
                font-size: 14px;
                color: var(--off-white);
                padding: 10px 0;
                border-bottom: 1px solid var(--border);
              "
              data-i18n="contact.prog.bjj"
            >
              Brazilian Jiu-Jitsu (Gi & No-Gi)
            </li>
            <li
              style="
                font-size: 14px;
                color: var(--off-white);
                padding: 10px 0;
                border-bottom: 1px solid var(--border);
              "
              data-i18n="contact.prog.grap"
            >
              Grappling & Wrestling
            </li>
            <li
              style="
                font-size: 14px;
                color: var(--off-white);
                padding: 10px 0;
                border-bottom: 1px solid var(--border);
              "
              data-i18n="contact.prog.mma"
            >
              MMA
            </li>
            <li
              style="
                font-size: 14px;
                color: var(--off-white);
                padding: 10px 0;
                border-bottom: 1px solid var(--border);
              "
              data-i18n="contact.prog.sc"
            >
              Strength & Conditioning
            </li>
            <li
              style="font-size: 14px; color: var(--off-white); padding: 10px 0"
              data-i18n="contact.prog.kids"
            >
              Kids & Youth Martial Arts
            </li>
          </ul>
        </div>
      </div>

      <div class="contact-form-wrap fade-up">
        <h2 data-i18n-html="contact.form.h2">
          Book Your
          <br />
          Free Trial
        </h2>
        <form id="contactForm" onsubmit="handleSubmit(event)">
          <input type="hidden" name="access_key" value="75b940bb-e6e1-4c51-a85b-041c8e53aa67" />
          <input type="hidden" name="subject" value="New enquiry – Ensō Athens" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="form-group">
            <input
              type="text"
              name="name"
              data-i18n-placeholder="form.name"
              placeholder="Full Name"
              required
            />
          </div>
          <div class="form-group">
            <input
              type="email"
              name="email"
              data-i18n-placeholder="form.email"
              placeholder="Email Address"
              required
            />
          </div>
          <div class="form-group">
            <input
              type="tel"
              name="phone"
              data-i18n-placeholder="form.phone"
              placeholder="Phone Number"
            />
          </div>
          <div class="form-group">
            <select
              name="program"
              style="
                width: 100%;
                background: transparent;
                border: none;
                border-bottom: 1px solid rgba(245, 240, 232, 0.15);
                padding: 14px 0;
                font-family: var(--font-body);
                font-size: 15px;
                font-weight: 300;
                color: rgba(245, 240, 232, 0.7);
                outline: none;
                cursor: pointer;
                appearance: none;
              "
            >
              <option
                value=""
                disabled
                selected
                style="background: #111"
                data-i18n="contact.form.program"
              >
                Interested in…
              </option>
              <option value="bjj" style="background: #111" data-i18n="contact.form.opt.bjj">
                Brazilian Jiu-Jitsu
              </option>
              <option value="grappling" style="background: #111" data-i18n="contact.form.opt.grap">
                Grappling
              </option>
              <option value="mma" style="background: #111" data-i18n="contact.form.opt.mma">
                MMA
              </option>
              <option value="sc" style="background: #111" data-i18n="contact.form.opt.sc">
                Strength & Conditioning
              </option>
              <option value="kids" style="background: #111" data-i18n="contact.form.opt.kids">
                Kids & Youth
              </option>
              <option value="corporate" style="background: #111" data-i18n="contact.form.opt.corp">
                Corporate Training
              </option>
            </select>
          </div>
          <div class="form-group">
            <textarea
              name="message"
              rows="5"
              data-i18n-placeholder="contact.form.message"
              placeholder="Any questions or additional info…"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary form-btn" data-i18n="contact.form.btn">
            Send Message
          </button>
          <p class="form-note" id="formNote"></p>
        </form>
      </div>
    </div>

    <!-- MAP EMBED -->
    <div style="height: 400px; overflow: hidden; border-top: 1px solid var(--border)">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3145.095245143133!2d23.71036797649176!3d37.97490650060553!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14a1bd9d8508fc35%3A0x43e80050a02b8c3d!2sEns%C5%8D%20Athens%20Martial%20Arts%20%26%20Jiu%20Jitsu!5e0!3m2!1sel!2sus!4v1776618907137!5m2!1sel!2sus"
        width="100%"
        height="100%"
        style="border: 0; filter: invert(90%) hue-rotate(180deg)"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ensō Athens Martial Arts location"
      ></iframe>
    </div>
</BaseLayout>

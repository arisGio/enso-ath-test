---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Functional Training – Ensō Athens Martial Arts">
<section class="page-hero page-hero--ft">
      <p class="page-hero-eyebrow" data-i18n="ft.hero.eyebrow">Services · Premium</p>
      <h1>
        STRENGTH &amp;
        <br />
        CONDITIONING
      </h1>
      <p data-i18n="ft.hero.p">
        Personalised functional training for athletes and professionals. Maximum three per session
        — real coaching, real results.
      </p>
      <a href="#contact-form" class="btn-primary" data-i18n="ft.hero.cta">Book a Session</a>
    </section>

    <!-- INTRO -->
    <section class="content-section fade-up">
      <div class="two-col">
        <div>
          <p class="section-eyebrow" data-i18n="ft.intro.eyebrow">The Training</p>
          <h2 data-i18n-html="ft.intro.h2">
            Function First.
            <br />
            <em>Performance</em> Always.
          </h2>
          <p data-i18n="ft.intro.p1">
            Our Strength &amp; Conditioning programme is built around your specific goals —
            whether that's athletic performance, injury prevention, or general fitness. Sessions
            are capped at three athletes so every movement is coached, every set is intentional.
          </p>
          <p data-i18n="ft.intro.p2">
            Expect evidence-based programming that adapts as you progress, delivered by coaches
            who understand both the gym floor and the demands of combat sports.
          </p>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon">◉</div>
            <div>
              <h4 data-i18n="ft.f1.h4">Max 3 Per Session</h4>
              <p data-i18n="ft.f1.p">Individualised attention you simply can't get in a large class</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">◉</div>
            <div>
              <h4 data-i18n="ft.f2.h4">Personalised Programming</h4>
              <p data-i18n="ft.f2.p">Training built around your body, history, and goals</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">◉</div>
            <div>
              <h4 data-i18n="ft.f3.h4">Athletes & Professionals</h4>
              <p data-i18n="ft.f3.p">Tailored for high performers inside and outside the gym</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">◉</div>
            <div>
              <h4 data-i18n="ft.f4.h4">Progress Tracking</h4>
              <p data-i18n="ft.f4.p">Measurable benchmarks at every phase of your programme</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FACILITY PHOTO -->
    <section class="about-teaser fade-up">
      <div class="about-teaser-img">
        <img
          src="/assets/faq-streght-and-conditioning-scaled.jpg"
          alt="Ensō Athens – Strength & Conditioning area"
          loading="lazy"
        />
      </div>
      <div class="about-teaser-text">
        <p class="section-eyebrow" data-i18n="ft.fac.eyebrow">The Facility</p>
        <h2 data-i18n-html="ft.fac.h2">
          Equipped to
          <br />
          Push You Further
        </h2>
        <p data-i18n="ft.fac.p">
          Our conditioning area is stocked with functional training equipment — barbells, kettlebells,
          resistance bands, and more. Designed alongside our BJJ mats to complement your
          martial arts training or stand alone as a premium small-group gym experience.
        </p>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-num">3</span>
            <span class="stat-label" data-i18n="ft.stat1">Max Per Session</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label" data-i18n="ft.stat2">Personalised</span>
          </div>
          <div class="stat">
            <span class="stat-num">IBJJF</span>
            <span class="stat-label" data-i18n="about-t.stat3">Certified Coaches</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PROGRAMS -->
    <section class="content-section fade-up">
      <p class="section-eyebrow" data-i18n="ft.prog.eyebrow">Programs</p>
      <h2 data-i18n="ft.prog.h2">Find Your Format</h2>
      <div class="program-cards" style="margin-top: 40px">
        <div class="program-card">
          <h3 data-i18n-html="ft.prog.c1.h3">
            <em>Semi-Private</em>
            Sessions
          </h3>
          <p data-i18n="ft.prog.c1.p">
            Train alongside one or two others at a similar level. Shared energy, individual
            coaching, and a cost-effective premium experience.
          </p>
          <ul>
            <li data-i18n="ft.prog.c1.li1">Up to 3 athletes per session</li>
            <li data-i18n="ft.prog.c1.li2">Structured warm-up, work, and cool-down</li>
            <li data-i18n="ft.prog.c1.li3">Weekly programming adjustments</li>
          </ul>
        </div>
        <div class="program-card">
          <h3 data-i18n-html="ft.prog.c2.h3">
            <em>Private</em>
            Coaching
          </h3>
          <p data-i18n="ft.prog.c2.p">
            One-on-one sessions for athletes who need laser-focused attention — injury
            rehabilitation, competition prep, or accelerated progress.
          </p>
          <ul>
            <li data-i18n="ft.prog.c2.li1">Full individual focus</li>
            <li data-i18n="ft.prog.c2.li2">Movement screening & goal mapping</li>
            <li data-i18n="ft.prog.c2.li3">Monthly progress reviews</li>
          </ul>
        </div>
        <div class="program-card">
          <h3 data-i18n-html="ft.prog.c3.h3">
            Martial Arts
            <em>Conditioning</em>
          </h3>
          <p data-i18n="ft.prog.c3.p">
            Purpose-built for BJJ, MMA, and grappling athletes. Develops the specific
            strength, endurance, and mobility your sport demands.
          </p>
          <ul>
            <li data-i18n="ft.prog.c3.li1">Sport-specific strength blocks</li>
            <li data-i18n="ft.prog.c3.li2">Energy system development</li>
            <li data-i18n="ft.prog.c3.li3">Injury prevention & mobility work</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- PILLARS -->
    <section class="content-section fade-up">
      <div class="two-col">
        <div>
          <p class="section-eyebrow" data-i18n="ft.pillars.eyebrow">Our Method</p>
          <h2 data-i18n="ft.pillars.h2">Built on Four Pillars</h2>
          <p data-i18n="ft.pillars.p">
            Every programme we write is grounded in the same four principles. Whether your
            goal is to compete at the highest level or simply move better every day, the
            framework stays the same — only the variables change.
          </p>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon">→</div>
            <div>
              <h4 data-i18n="ft.pil1.h4">Strength Foundation</h4>
              <p data-i18n="ft.pil1.p">Compound movements that build transferable, real-world power</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">→</div>
            <div>
              <h4 data-i18n="ft.pil2.h4">Conditioning Capacity</h4>
              <p data-i18n="ft.pil2.p">Aerobic and anaerobic work matched to your sport or lifestyle</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">→</div>
            <div>
              <h4 data-i18n="ft.pil3.h4">Mobility & Resilience</h4>
              <p data-i18n="ft.pil3.p">Stay injury-free and move through full ranges with control</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">→</div>
            <div>
              <h4 data-i18n="ft.pil4.h4">Mental Toughness</h4>
              <p data-i18n="ft.pil4.p">Structured discomfort that builds focus and grit under pressure</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO IT'S FOR -->
    <section class="content-section fade-up">
      <p class="section-eyebrow" data-i18n="ft.who.eyebrow">Who It's For</p>
      <h2 data-i18n="ft.who.h2">Built for High Performers</h2>
      <div class="feature-list" style="max-width: 700px; margin-top: 32px">
        <div class="feature-item">
          <div class="feature-icon">◎</div>
          <div>
            <h4 data-i18n="ft.who.f1.h4">Martial Artists</h4>
            <p data-i18n="ft.who.f1.p">BJJ, MMA, or grappling athletes seeking a performance edge</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">◎</div>
          <div>
            <h4 data-i18n="ft.who.f2.h4">Busy Professionals</h4>
            <p data-i18n="ft.who.f2.p">Efficient, high-impact sessions that respect your schedule</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">◎</div>
          <div>
            <h4 data-i18n="ft.who.f3.h4">Returning Athletes</h4>
            <p data-i18n="ft.who.f3.p">Rebuilding after injury with careful, progressive programming</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">◎</div>
          <div>
            <h4 data-i18n="ft.who.f4.h4">General Fitness</h4>
            <p data-i18n="ft.who.f4.p">Anyone who wants structured coaching without a big group</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section" id="contact-form">
      <div class="cta-left">
        <p class="section-eyebrow" data-i18n="cta.eyebrow">Get Started</p>
        <h2 data-i18n-html="ft.cta.h2">
          Train Smarter.
          <br />
          Perform
          <br />
          Better.
        </h2>
        <p data-i18n="ft.cta.p1">
          Small groups, expert coaching, and programming that actually fits your life.
        </p>
        <p style="margin-top: 8px"><strong data-i18n="cta.p">Train. Learn. Evolve.</strong></p>
        <div class="cta-contact-details">
          <p><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;vertical-align:middle;flex-shrink:0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l1.8-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg> <a href="tel:+306971767652">+30 697 176 7652</a></p>
          <p><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;vertical-align:middle;flex-shrink:0"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> <a href="mailto:ensoathens@gmail.com">ensoathens@gmail.com</a></p>
          <p><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;vertical-align:middle;flex-shrink:0"><path d="M20 10c0 6-8 13-8 13s-8-7-8-13a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg> <a href="https://www.google.com/maps/place/Ens%C5%8D+Athens+Martial+Arts+%26+Jiu+Jitsu/@37.9749023,23.710368,17z/data=!3m1!4b1!4m6!3m5!1s0x14a1bd9d8508fc35:0x43e80050a02b8c3d!8m2!3d37.9749023!4d23.7129429!16s%2Fg%2F11vry4tz08?entry=ttu&g_ep=EgoyMDI2MDQxNS4wIKXMDSoASAFQAw%3D%3D" target="_blank" rel="noopener"><span data-i18n="cta.location">Thessalonikis 35, Athens 11851</span></a></p>
        </div>
      </div>
      <div class="cta-form">
        <form id="contactForm" onsubmit="handleSubmit(event)">
          <div class="form-group">
            <input type="text" name="name" data-i18n-placeholder="form.name" placeholder="Full Name" required />
          </div>
          <div class="form-group">
            <input type="email" name="email" data-i18n-placeholder="form.email" placeholder="Email Address" required />
          </div>
          <div class="form-group">
            <input type="tel" name="phone" data-i18n-placeholder="form.phone" placeholder="Phone Number" />
          </div>
          <div class="form-group">
            <textarea name="message" rows="4" data-i18n-placeholder="ft.form.message" placeholder="Interested in Strength & Conditioning? Ask us anything…"></textarea>
          </div>
          <button type="submit" class="btn-primary form-btn" data-i18n="form.btn">Book My Free Trial</button>
          <p class="form-note" id="formNote"></p>
        </form>
      </div>
    </section>
</BaseLayout>
